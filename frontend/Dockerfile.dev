# Development Dockerfile with live reload
FROM node:22-alpine

WORKDIR /app

COPY package*.json ./

RUN npm install --no-audit --no-fund --ignore-scripts

COPY index.html vite.config.js tailwind.config.js eslint.config.js ./
COPY public ./public
COPY src ./src
COPY scripts ./scripts

EXPOSE 5173
ENV BIND_ADDR=0.0.0.0

# Run as non-root user for improved security
USER node

CMD ["sh", "-c", "npm run dev -- --host ${BIND_ADDR}"]