# Development Dockerfile with live reload
FROM node:22-alpine

# Install curl for healthcheck
RUN apk add --no-cache curl

WORKDIR /app

# Setup ownership early
RUN chown node:node /app

# Copy package files first
COPY --chown=root:root --chmod=555 package*.json ./

# Use cache mount for faster dev installs
RUN --mount=type=cache,target=/root/.npm \
    npm install --no-audit --no-fund --ignore-scripts

# Explicitly copy needed directories to prevent recursive sensitive data copy
COPY --chown=root:root --chmod=555 index.html vite.config.js tailwind.config.js eslint.config.js ./
COPY --chown=root:root --chmod=555 src/ ./src/
COPY --chown=root:root --chmod=555 public/ ./public/
COPY --chown=root:root --chmod=555 scripts/ ./scripts/

# EXPOSE 5173
ENV BIND_ADDR=0.0.0.0

# Run as non-root user
USER node

CMD ["sh", "-c", "npm run dev -- --host ${BIND_ADDR}"]
