# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/iam_auth?schema=public"

# JWT Secrets
JWT_ACCESS_SECRET="your-access-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Email (Ethereal for dev - auto-generated)
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/oauth/google/callback"

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:5000/api/auth/oauth/github/callback"

# Security
BCRYPT_ROUNDS=12
ACCOUNT_LOCK_DURATION_MINUTES=30
MAX_FAILED_LOGIN_ATTEMPTS=5
PASSWORD_RESET_EXPIRY_HOURS=1
