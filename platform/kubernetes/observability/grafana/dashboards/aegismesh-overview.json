        { "expr": "histogram_quantile(0.95, sum(rate(security_engine_inference_duration_seconds_bucket[5m])) by (le))", "legendFormat": "ML Inference", "refId": "B" }
      ],
      "title": "Latency Breakdown: Data vs Logic",
