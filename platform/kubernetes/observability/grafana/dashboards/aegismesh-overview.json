        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 9,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(aegismesh_audit_log_writes_total{result=\"failure\"}[1h]))", "legendFormat": "Failures", "refId": "A" }],
      "title": "Audit Write Failures",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "panels": [],
      "title": "System Performance & Resource Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(aegismesh_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95 Latency", "refId": "A" },
        { "expr": "histogram_quantile(0.50, sum(rate(aegismesh_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50 Latency", "refId": "B" }
      ],
      "title": "API Latency Profiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10, "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "aegismesh_nodejs_heap_size_used_bytes", "legendFormat": "Heap Used", "refId": "A" },
        { "expr": "aegismesh_nodejs_heap_size_total_bytes", "legendFormat": "Heap Total", "refId": "B" }
      ],
      "title": "Node.js Memory Utilization",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 102,
      "panels": [],
      "title": "Security & Audit Intelligence",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "aegismesh-postgres" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "aegismesh-postgres" },
        "format": "time_series",
        "rawSql": "SELECT $__timeGroup(\"createdAt\", '1h') AS time, COUNT(*) AS audit_events FROM \"AuditLog\" WHERE $__timeFilter(\"createdAt\") GROUP BY time ORDER BY time;",
        "refId": "A"
      }],
      "title": "Audit Log Velocity",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "aegismesh-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 7,
      "options": { "cellHeight": "sm", "showHeader": true },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "aegismesh-postgres" },
        "format": "table",
        "rawSql": "SELECT action, result, category, COUNT(*) AS count FROM \"AuditLog\" WHERE $__timeFilter(\"createdAt\") GROUP BY action, result, category ORDER BY count DESC LIMIT 20;",
        "refId": "A"
      }],
      "title": "Top Audit Actions",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{ "expr": "sum by (action, result) (rate(aegismesh_auth_events_total[5m]))", "legendFormat": "{{action}} ({{result}})", "refId": "A" }],
      "title": "Auth Lifecycle",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{ "expr": "sum by (action, severity) (rate(aegismesh_security_events_total[5m]))", "legendFormat": "{{action}} [{{severity}}]", "refId": "A" }],
      "title": "Security Triggers",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 12,
