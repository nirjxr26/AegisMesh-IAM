      "targets": [{ "expr": "sum by (action, result) (rate(aegismesh_permission_events_total[5m]))", "legendFormat": "{{action}} ({{result}})", "refId": "A" }],
      "title": "Access Denials",
      "type": "timeseries"
    },
    {
      "collapsed": false,
