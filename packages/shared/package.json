{
  "name": "@aegismesh/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared constants, formatters, and utilities for AegisMesh IAM",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./constants": {
      "import": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    },
    "./formatters": {
      "import": "./dist/formatters.js",
      "types": "./dist/formatters.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "echo ok"
  }
}
