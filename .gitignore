# ═══════════════════════════════════════════════════════════════
# AegisMesh IAM - Global Git Ignore
# ═══════════════════════════════════════════════════════════════

# ── Environment & Secrets ──────────────────────────────────────
.env
.env.local
.env.*.local
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.cred
credentials-*

# ── Dependencies ────────────────────────────────────────────────
node_modules/

# ── Build Outputs ───────────────────────────────────────────────
dist/
build/
*.tsbuildinfo
packages/*/dist/
coverage/
.nyc_output/

# ── Logs ────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.pyc

# ── Infrastructure ──────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.backup
terraform.tfvars
terraform/*.tfvars
terraform/*.tfvars.json
terraform/crash.log
terraform/**/*.tfstate
kubeconfig*
**/kubeconfig*
.kube/
*.sql
*.sql.gz
pg_dump*
pg_dumpall*
*secrets*.yaml
*secrets*.yml
db_data/

# ── IDE & Editor ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ── Temporary / Cache ───────────────────────────────────────────
tmp/
temp/
*.tmp
backups/
.turbo/
.datadog/
.kpatch/
.continue/

# ── Agent / CLI Artifacts ──────────────────────────────────────
.aider*
.antigravitycli/
.claude/
.agents/
.sonarqube_report/
.code-quality/
.archive/
.jenkins/

# ── Local Dev Scripts (not needed in CI) ───────────────────────
scripts/ci/sonar-report.js
scripts/ci/scan-repo/
