# ═══════════════════════════════════════════════════════════════
# AegisMesh IAM - Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ═══════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
DB_NAME=iam_auth
DB_USER=iam_user
DB_PASSWORD=your_secure_database_password_here
DB_PORT=5432
DATABASE_URL=postgresql://iam_user:your_secure_database_password_here@localhost:5432/iam_auth

# ═══════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════
PORT=5000
BACKEND_PORT=5000
FRONTEND_PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════
# JWT SECRETS & CONFIGURATION (Generate secure random strings)
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=your_secure_jwt_secret_key_min_32_chars_long
JWT_ACCESS_SECRET=your_secure_access_token_secret_key_32_chars
JWT_REFRESH_SECRET=your_secure_refresh_token_secret_key_32_chars
JWT_EXPIRY=15m
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ═══════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════
VITE_API_URL=http://localhost:5000

# ═══════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (SMTP) - Use your mail service
# ═══════════════════════════════════════════════════════════════
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your_email@provider.com
SMTP_PASS=your_email_password_or_app_password
SMTP_FROM=noreply@aegismesh.com

# ═══════════════════════════════════════════════════════════════
# OAUTH CONFIGURATION - Get keys from OAuth providers
# ═══════════════════════════════════════════════════════════════
# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/oauth/google/callback

# GitHub OAuth - https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/oauth/github/callback

# ═══════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════
BCRYPT_ROUNDS=12
ACCOUNT_LOCK_DURATION_MINUTES=30
MAX_FAILED_LOGIN_ATTEMPTS=5
PASSWORD_RESET_EXPIRY_HOURS=1

# ═══════════════════════════════════════════════════════════════
# AUDIT LOG RETENTION (in days)
# ═══════════════════════════════════════════════════════════════
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_SECURITY_LOG_RETENTION_DAYS=365

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info
